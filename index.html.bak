<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Free Fire Long Bio - Full Video Edition</title>
    <style>
        /* إلغاء الأطراف تماماً لجعل التطبيق شاشة كاملة حقيقية */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #060913;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        /* الصندوق يمثل الشاشة كاملة 100% */
        .main-card {
            position: relative;
            width: 100%;
            height: 100%;
            box-sizing: border-box;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        /* جعل الفيديو يظهر بكامل وضوحه وألوانه الأصلية ويمتد للشاشة كاملة */
        .inner-video-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
        }

        /* تقليل التعتيم تماماً لإظهار الفيديو 100% بوضوح نيون العينين والخلفية */
        .inner-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(6, 9, 19, 0.45); /* تعتيم خفيف جداً يبرز الفيديو بالكامل */
            z-index: 2;
        }

        /* حاوية المحتوى المباشر فوق الفيديو */
        .content-container {
            position: relative;
            z-index: 3;
            width: 100%;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .form-body {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* عنوان متناسق ومضيء */
        h2 {
            text-align: center;
            color: #00d2ff;
            margin-top: 0;
            margin-bottom: 4px;
            font-size: 26px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 0 0 15px rgba(0, 210, 255, 0.8), 0 2px 4px rgba(0,0,0,0.8);
        }

        .subtitle {
            text-align: center;
            color: #ffffff;
            font-size: 13px;
            margin-bottom: 24px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            color: #00d2ff;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
        }

        /* حقول إدخال زرقاء داكنة شفافة ومريحة فوق الفيديو المضيء */
        input[type="text"], textarea {
            width: 100%;
            padding: 14px;
            border: 1px solid rgba(0, 210, 255, 0.3);
            border-radius: 12px;
            background-color: rgba(4, 8, 17, 0.85);
            color: #ffffff;
            box-sizing: border-box;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            backdrop-filter: blur(3px); /* تأثير زجاجي ناعم فوق الفيديو */
        }

        input[type="text"]:focus, textarea:focus {
            border-color: #00d2ff;
            box-shadow: 0 0 12px rgba(0, 210, 255, 0.5);
            outline: none;
        }

        textarea {
            resize: none;
            height: 85px;
        }

        /* لوحة الألوان بتصميم شفاف ومتناسق */
        .color-palette {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
            background: rgba(4, 8, 17, 0.85);
            padding: 12px;
            border-radius: 12px;
            border: 1px solid rgba(0, 210, 255, 0.2);
            backdrop-filter: blur(3px);
        }

        .color-box {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.2);
            transition: transform 0.2s;
        }

        .color-box:hover {
            transform: scale(1.18);
        }

        /* صندوق المعاينة مدمج ومتناسق */
        .preview-box {
            width: 100%;
            min-height: 55px;
            padding: 14px;
            background-color: rgba(4, 8, 17, 0.85);
            border: 1px dashed rgba(0, 210, 255, 0.3);
            border-radius: 12px;
            color: #ffffff;
            font-size: 14px;
            box-sizing: border-box;
            white-space: pre-wrap;
            word-wrap: break-word;
            backdrop-filter: blur(3px);
        }

        /* زر تغيير البايو بلون نيون أزرق ممتد ومضيء */
        button {
            width: 100%;
            padding: 15px;
            background: linear-gradient(90deg, #005c97, #00d2ff);
            border: none;
            border-radius: 12px;
            color: #ffffff;
            font-size: 16px;
            cursor: pointer;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0, 210, 255, 0.4);
            margin-top: 8px;
        }

        button:hover {
            background: linear-gradient(90deg, #0077b6, #00e5ff);
            box-shadow: 0 4px 25px rgba(0, 229, 255, 0.6);
        }

        #result {
            margin-top: 12px;
            padding: 12px;
            border-radius: 10px;
            display: none;
            font-size: 14px;
            font-weight: bold;
            text-align: center;
        }

        .success { background-color: rgba(46, 213, 115, 0.3); color: #2ed573; border: 1px solid #2ed573; }
        .error { background-color: rgba(255, 71, 87, 0.3); color: #ff4757; border: 1px solid #ff4757; }

        /* حاوية زر التليجرام بالداخل أسفل الشاشة تماماً */
        .inner-footer {
            margin-top: auto;
            padding-top: 15px;
            text-align: center;
            width: 100%;
        }

        .tg-icon-btn {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            width: 50px;
            height: 50px;
            background-color: rgba(4, 8, 17, 0.85);
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(0,0,0,0.6);
            transition: all 0.3s ease;
            text-decoration: none;
            border: 1px solid rgba(0, 210, 255, 0.2);
        }

        .tg-icon-btn:hover {
            transform: scale(1.1);
            background-color: #00d2ff;
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.6);
        }

        .tg-icon-btn svg {
            width: 22px;
            height: 22px;
            fill: #00d2ff;
        }

        .tg-icon-btn:hover svg {
            fill: #000000;
        }
    </style>
</head>
<body>

<div class="main-card">
    <video autoplay loop muted playsinline class="inner-video-bg">
        <source src="Video.mp4" type="video/mp4">
    </video>
    
    <div class="inner-overlay"></div>

    <div class="content-container">
        <div class="form-body">
            <h2>⚡ Free Fire Long Bio</h2>
            <div class="subtitle">Customize your profile with premium neon vibes</div>
            
            <div class="form-group">
                <label>🔑 Access Token</label>
                <input type="text" id="accessToken" placeholder="Paste your access token or URL here...">
            </div>

            <div class="form-group">
                <label>✏️ New Bio</label>
                <textarea id="bio" oninput="updatePreview()" placeholder="Type your new bio... Use color palette below"></textarea>
                
                <div class="color-palette">
                    <div class="color-box" style="background-color: #FF0000;" onclick="insertColorCode('FF0000')"></div>
                    <div class="color-box" style="background-color: #00FF00;" onclick="insertColorCode('00FF00')"></div>
                    <div class="color-box" style="background-color: #0000FF;" onclick="insertColorCode('0000FF')"></div>
                    <div class="color-box" style="background-color: #FFFF00;" onclick="insertColorCode('FFFF00')"></div>
                    <div class="color-box" style="background-color: #FF00FF;" onclick="insertColorCode('FF00FF')"></div>
                    <div class="color-box" style="background-color: #00FFFF;" onclick="insertColorCode('00FFFF')"></div>
                    <div class="color-box" style="background-color: #FFA500;" onclick="insertColorCode('FFA500')"></div>
                    <div class="color-box" style="background-color: #8B00FF;" onclick="insertColorCode('8B00FF')"></div>
                    <div class="color-box" style="background-color: #FFC0CB;" onclick="insertColorCode('FFC0CB')"></div>
                    <div class="color-box" style="background-color: #FFFFFF;" onclick="insertColorCode('FFFFFF')"></div>
                    <div class="color-box" style="background-color: #FF4500;" onclick="insertColorCode('FF4500')"></div>
                    <div class="color-box" style="background-color: #1E90FF;" onclick="insertColorCode('1E90FF')"></div>
                </div>
            </div>

            <div class="form-group">
                <label>👁️ Bio Preview</label>
                <div id="bioPreview" class="preview-box">Your bio preview will appear here...</div>
            </div>

            <button id="submitBtn" onclick="updateBio()">🚀 Change Bio</button>

            <div id="result"></div>
        </div>

        <div class="inner-footer">
            <a href="https://t.me/Z_7_K_R" target="_blank" class="tg-icon-btn">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-1-.65-.35-1 .22-1.62.15-.15 2.7-2.46 2.75-2.67.01-.03.01-.14-.06-.2-.07-.06-.17-.04-.24-.02-.1.02-1.69 1.07-4.77 3.14-.45.3-.86.46-1.22.45-.4-.01-1.17-.23-1.74-.41-.7-.23-1.26-.35-1.21-.74.03-.2.3-.41.82-.62 3.2-1.39 5.34-2.31 6.42-2.75 3.05-1.25 3.68-1.47 4.1-.15.09.2.09.43.06.66z"/>
                </svg>
            </a>
        </div>
    </div>
</div>

<script>
    function insertColorCode(hex) {
        const bioTextarea = document.getElementById('bio');
        bioTextarea.value += `[${hex}]`;
        bioTextarea.focus();
        updatePreview();
    }

    function updatePreview() {
        const text = document.getElementById('bio').value;
        const preview = document.getElementById('bioPreview');
        
        if (!text.trim()) {
            preview.innerHTML = "Your bio preview will appear here...";
            return;
        }

        let formatted = text.replace(/\[([0-9A-Fa-f]{6})\]([^\[]*)/g, function(match, hex, content) {
            return `<span style="color: #${hex};">${content}</span>`;
        });

        formatted = formatted.replace(/\[b\]/gi, '<b>').replace(/\[\/b\]/gi, '</b>');
        formatted = formatted.replace(/\[i\]/gi, '<u>').replace(/\[\/i\]/gi, '</u>');

        preview.innerHTML = formatted;
    }

    async function updateBio() {
        const token = document.getElementById('accessToken').value.trim();
        const bio = document.getElementById('bio').value.trim();
        const resultDiv = document.getElementById('result');
        const submitBtn = document.getElementById('submitBtn');
        const apiKey = 'paglu_dev';

        if (!token || !bio) {
            showResult('⚠️ Please fill out both fields!', 'error');
            return;
        }

        submitBtn.disabled = true;
        submitBtn.innerText = "Processing... ⏳";
        resultDiv.style.display = 'none';

        const apiUrl = `https://bio.ffutils.tech/api/update_bio?access_token=${encodeURIComponent(token)}&bio=${encodeURIComponent(bio)}&key=${apiKey}`;

        try {
            const response = await fetch(apiUrl);
            const data = await response.json();

            if (data.status === 'success') {
                showResult(`
                    🎉 Bio Updated Successfully!<br>
                    👤 Nickname: ${data.nickname || 'Unknown'}<br>
                    🆔 UID: ${data.uid || 'Unknown'}
                `, 'success');
            } else {
                showResult(`❌ Error: ${data.message || 'Failed'}`, 'error');
            }
        } catch (error) {
            showResult('❌ API request failed.', 'error');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = "🚀 Change Bio";
        }
    }

    function showResult(message, type) {
        const resultDiv = document.getElementById('result');
        resultDiv.className = type;
        resultDiv.innerHTML = message;
        resultDiv.style.display = 'block';
    }
</script>

</body>
</html>
